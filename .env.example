# ─── Required ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/learnagenticpatterns
JWT_SECRET=your-secret-key-minimum-32-characters-long

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@learnagenticpatterns.com
ADMIN_EMAIL=admin@learnagenticpatterns.com

# ─── Telegram Notifications ────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
RESEND_AUDIENCE_ID=aud_xxxxxxxxxxxx

# ─── AI Assessment (Google Gemini) ───────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── Site ────────────────────────────────────────────────────
SITE_URL=https://learnagenticpatterns.com
PORT=3000

# ─── Admin ───────────────────────────────────────────────────
ADMIN_SECRET=your-admin-secret-for-stats-endpoint

# ─── Monitoring (optional) ───────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Analytics (optional) ───────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
